/**
 * @fileoverview Firestore Security Rules for NetTech Solutions.
 *
 * Core Philosophy:
 * This ruleset enforces a role-based access control system combined with user-ownership for data privacy.
 * User data and related subcollections (cart items, orders, reviews) are strictly controlled, allowing only the authenticated user and admins access.
 * Public data, such as product information, is readable by all, but write access is restricted.
 * Admin privileges, managed via the `/roles_admin/{userId}` collection, grant elevated permissions.
 *
 * Data Structure:
 * - /products/{productId}: Publicly readable product information.
 * - /users/{userId}: User profile data; write access restricted to the user and admins.
 * - /users/{userId}/cart_items/{cartItemId}: Cart items owned by the user.
 * - /users/{userId}/orders/{orderId}: Order history for the user.
 * - /orders/{orderId}/order_items/{orderItemId}: Items within a specific order.
 * - /users/{userId}/reviews/{reviewId}: Product reviews created by the user.
 * - /newsletter_subscriptions/{subscriptionId}: Newsletter subscriptions; publicly creatable, restricted otherwise.
 * - /roles_admin/{userId}: Indicates admin privileges; presence of a document grants admin status.
 *
 * Key Security Decisions:
 * - User listing is disallowed to protect privacy.
 * - Admin privileges are checked via document existence in the `/roles_admin/{userId}` collection for simplicity and performance.
 * - The `isAdmin` field is denormalized into the user document for authorization independence.
 * - Default security posture is strict: any access not explicitly allowed is denied.
 * - To create simpler, more performant rules, roles, and ownership are denormalized onto the documents being secured.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows anyone to read product information, but restricts creation, updates, and deletion.
     * @path /products/{productId}
     * @allow (get, list): if true
     * @deny (create, update, delete): if false
     * @principle Public read, restricted write.
     */
    match /products/{productId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Controls access to user profile information. Only the user and admins can read/write.
     * @path /users/{userId}
     * @allow (get, update, delete): if request.auth != null && (request.auth.uid == userId || isAdmin())
     * @allow create: if request.auth != null
     * @deny (create, update, delete): if request.auth == null || (request.auth.uid != userId && !isAdmin())
     * @principle Enforces user-ownership for writes, admin override.
     */
    match /users/{userId} {
      allow get: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow list: if false;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    /**
     * @description Restricts access to cart items to the owning user.
     * @path /users/{userId}/cart_items/{cartItemId}
     * @allow (get, list, create, update, delete): if request.auth != null && request.auth.uid == userId
     * @deny (get, list, create, update, delete): if request.auth == null || request.auth.uid != userId
     * @principle Enforces user-ownership for writes.
     */
    match /users/{userId}/cart_items/{cartItemId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow list: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    /**
     * @description Restricts access to order history to the owning user.
     * @path /users/{userId}/orders/{orderId}
     * @allow (get, list, create, update, delete): if request.auth != null && request.auth.uid == userId
     * @deny (get, list, create, update, delete): if request.auth == null || request.auth.uid != userId
     * @principle Enforces user-ownership for writes.
     */
    match /users/{userId}/orders/{orderId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow list: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

        /**
     * @description Restricts access to order items to the owning order.
     * @path /orders/{orderId}/order_items/{orderItemId}
     * @allow (get, list, create, update, delete): if false; // No direct access
     * @deny (get, list, create, update, delete): if true
     */
    match /orders/{orderId}/order_items/{orderItemId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Restricts access to product reviews to the owning user.
     * @path /users/{userId}/reviews/{reviewId}
     * @allow (get, list, create, update, delete): if request.auth != null && request.auth.uid == userId
     * @deny (get, list, create, update, delete): if request.auth == null || request.auth.uid != userId
     * @principle Enforces user-ownership for writes.
     */
    match /users/{userId}/reviews/{reviewId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow list: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    /**
     * @description Allows anyone to create a newsletter subscription, but restricts reading and modification.
     * @path /newsletter_subscriptions/{subscriptionId}
     * @allow create: if true
     * @deny (get, list, update, delete): if false
     * @principle Public create, restricted access.
     */
    match /newsletter_subscriptions/{subscriptionId} {
      allow get: if false;
      allow list: if false;
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }

     /**
      * @description Grants admin privileges to users with a document present in this collection.
      * @path /roles_admin/{userId}
      */
     match /roles_admin/{userId} {
        allow get: if request.auth != null && request.auth.uid == userId;
        allow list: if isAdmin();
        allow create: if isAdmin();
        allow update: if false;
        allow delete: if isAdmin();
     }

  }

  // Helper functions
  function isSignedIn() {
    return request.auth != null;
  }

  function isAdmin() {
    return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
  }
}
